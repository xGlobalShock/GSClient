{
  "name": "gs-center",
  "version": "1.8.1",
  "description": "GS Center - Advanced System Optimization Tool",
  "author": "GS Center Team",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "react-start": "cross-env NODE_OPTIONS=--no-deprecation NODE_MAX_OLD_SPACE_SIZE=4096 GENERATE_SOURCEMAP=false EXTEND_ESLINT=true SKIP_PREFLIGHT_CHECK=true react-scripts start",
    "react-build": "cross-env NODE_MAX_OLD_SPACE_SIZE=4096 SKIP_PREFLIGHT_CHECK=true react-scripts build",
    "react-test": "react-scripts test",
    "electron-dev": "cross-env NODE_OPTIONS=--no-deprecation NODE_MAX_OLD_SPACE_SIZE=4096 concurrently --names \"REACT,ELECTRON\" --prefix-colors \"cyan.bold,magenta.bold\" --kill-others-on-fail --hide-from-output REACT \"npm --silent run react-start\" \"wait-on http://localhost:3000 --timeout 120000 && electron .\"",
    "electron-only": "cross-env NODE_OPTIONS=--no-deprecation NODE_MAX_OLD_SPACE_SIZE=4096 concurrently --silent --names \"REACT,ELECTRON\" --prefix-colors \"cyan.bold,magenta.bold\" --kill-others-on-fail --hide-from-output REACT \"cross-env BROWSER=none npm --silent run react-start\" \"wait-on http://localhost:3000 --timeout 120000 && electron .\"",
    "electron-build": "npm --silent run react-build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --publish never",
    "postelectron-build": "node scripts/rename-output.js",
    "start": "npm run electron-dev",
    "build": "npm run electron-build",
    "dev": "npm run electron-dev",
    "client": "node electron/dev-launcher.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^10.16.4",
    "is-admin": "^4.0.0",
    "lucide-react": "^0.292.0",
    "node-pty": "^1.1.0",
    "ogl": "^1.0.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "systeminformation": "^5.31.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "cross-env": "^10.1.0",
    "electron": "^27.0.0",
    "electron-builder": "^23.6.0",
    "postcss": "^8.4.31",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.3.5",
    "typescript": "^6.0.2",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.gscontrolcenter.app",
    "productName": "GS Center",
    "asar": true,
    "files": [
      "build/**/*",
      "electron/**/*",
      "main-process/**/*",
      "lib/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/**/*.dll",
      "node_modules/node-pty/**"
    ],
    "extraFiles": [
      {
        "from": "public/app.manifest",
        "to": "app.manifest"
      }
    ],
    "extraResources": [
      {
        "from": "public/app-icons",
        "to": "app-icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "lib",
        "to": "lib",
        "filter": [
          "**/*.dll",
          "**/*.exe"
        ]
      },
      {
        "from": "V-Config",
        "to": "V-Config",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src/data/obsPresetConfigs",
        "to": "data/obsPresetConfigs",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "public"
    },
    "icon": "public/app-icons/GSC.ico",
    "extends": null,
    "publish": {
      "provider": "github",
      "owner": "xGlobalShock",
      "repo": "GS-Center"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "GS Center",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "GS Center",
      "artifactName": "GS-Center-Setup-${version}.${ext}",
      "installerIcon": "public/app-icons/GSC.ico",
      "uninstallerIcon": "public/app-icons/GSC.ico",
      "installerHeaderIcon": "public/app-icons/GSC.ico",
      "include": "installer.nsh"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
